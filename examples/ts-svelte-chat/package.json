    "@tanstack/ai-svelte": "workspace:*",
    "highlight.js": "^11.11.1",
    "lucide-svelte": "^0.577.0",
    "marked": "^15.0.12",
    "marked-highlight": "^2.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.3.1",
